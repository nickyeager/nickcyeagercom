---
const title = 'Nick C. Yeager';
const description = 'AI Solutions Architect. Speaker. Builder.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { overflow: hidden; background: #050508; }

      canvas#fractal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: block;
      }

      .overlay {
        position: fixed;
        bottom: 32px;
        left: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        color: #C8C8C8;
        line-height: 1.8;
        pointer-events: auto;
        padding: 20px 24px;
        background: rgba(5, 5, 8, 0.55);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(140, 160, 220, 0.1);
        border-radius: 6px;
      }

      .overlay .name {
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        font-weight: 600;
        color: #e0e0e0;
        letter-spacing: 0.02em;
        margin-bottom: 2px;
      }

      .overlay .tagline {
        font-size: clamp(0.65rem, 1.2vw, 0.78rem);
        color: #585858;
        margin-bottom: 16px;
        letter-spacing: 0.04em;
      }

      .overlay .links {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .overlay a {
        font-size: clamp(0.7rem, 1.1vw, 0.82rem);
        color: #8EAADC;
        text-decoration: none;
        transition: color 0.3s ease, text-shadow 0.3s ease;
        width: fit-content;
      }

      .overlay a:hover {
        color: #B8D0FF;
        text-shadow: 0 0 12px rgba(140, 170, 220, 0.4);
      }

      .overlay .nav-links {
        display: flex;
        gap: 16px;
        margin-top: 16px;
        padding-top: 12px;
        border-top: 1px solid rgba(140, 160, 220, 0.15);
      }

      .overlay .nav-links a {
        color: #585858;
        font-size: clamp(0.6rem, 1vw, 0.72rem);
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .overlay .nav-links a:hover {
        color: #C8C8C8;
        text-shadow: none;
      }

      .hint {
        position: fixed;
        bottom: 32px;
        right: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        color: #333;
        letter-spacing: 0.08em;
        transition: opacity 0.8s ease;
      }

      @media (max-width: 640px) {
        .overlay { bottom: 20px; left: 20px; }
        .hint { bottom: 20px; right: 20px; }
      }
    </style>
  </head>
  <body>
    <canvas id="fractal"></canvas>

    <div class="overlay">
      <div class="name">Nick C. Yeager</div>
      <div class="tagline">AI Solutions Architect / Speaker / Tucson, AZ</div>
      <div class="links">
        <a href="https://github.com/nickyeager" target="_blank" rel="noopener">github</a>
        <a href="https://www.linkedin.com/in/nicholas-yeager/" target="_blank" rel="noopener">linkedin</a>
        <a href="mailto:yeag123@gmail.com">yeag123@gmail.com</a>
      </div>
      <div class="nav-links">
        <a href="/about">about</a>
        <a href="/blog">blog</a>
        <a href="/talks">talks</a>
        <a href="/fractal">what is this?</a>
      </div>
    </div>

    <div class="hint" id="hint">drag to rotate · scroll to zoom</div>

    <script>
      import * as THREE from 'three';

      // ─── Adaptive Quality ───
      const baseDpr = Math.min(window.devicePixelRatio, 1.5);
      let currentScale = 0.7;
      let targetScale = 0.7;
      function getEffectiveDpr() { return baseDpr * currentScale; }

      // ─── Setup ───
      const canvas = document.getElementById('fractal') as HTMLCanvasElement;
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: false });
      renderer.setPixelRatio(getEffectiveDpr());
      renderer.setSize(window.innerWidth, window.innerHeight);

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

      // ─── Fractal Shader ───
      const vertexShader = `
        void main() {
          gl_Position = vec4(position, 1.0);
        }
      `;

      const fragmentShader = `
        precision highp float;

        uniform vec2 uResolution;
        uniform float uTime;
        uniform vec2 uMouse;
        uniform float uZoom;

        #define MAX_STEPS 80
        #define MAX_DIST 16.0
        #define MIN_DIST 0.001
        #define ITERATIONS 8

        // Cosine palette — indigo / violet / steel
        vec3 palette(float t) {
          vec3 a = vec3(0.28, 0.3, 0.58);
          vec3 b = vec3(0.18, 0.2, 0.35);
          vec3 c = vec3(1.0, 1.0, 1.0);
          vec3 d = vec3(0.0, 0.05, 0.15);
          return a + b * cos(6.28318 * (c * t + d));
        }

        // Mandelbox distance estimator
        vec2 mandelbox(vec3 pos) {
          float scale = -1.77 + sin(uTime * 0.08) * 0.05;
          vec3 z = pos;
          float dz = 1.0;
          float trap = 1e10;

          for (int i = 0; i < ITERATIONS; i++) {
            z = clamp(z, -1.0, 1.0) * 2.0 - z;
            float r2 = dot(z, z);
            if (r2 < 0.25) {
              z *= 4.0; dz *= 4.0;
            } else if (r2 < 1.0) {
              float t = 1.0 / r2;
              z *= t; dz *= t;
            }
            z = scale * z + pos;
            dz = dz * abs(scale) + 1.0;
            trap = min(trap, length(z));
          }

          return vec2(length(z) / abs(dz), trap);
        }

        // Rotation matrix
        mat3 rotateXY(vec2 angle) {
          float cx = cos(angle.x), sx = sin(angle.x);
          float cy = cos(angle.y), sy = sin(angle.y);
          return mat3(
            cy, 0.0, sy,
            sx * sy, cx, -sx * cy,
            -cx * sy, sx, cx * cy
          );
        }

        // Scene SDF
        vec2 map(vec3 p) {
          return mandelbox(rotateXY(uMouse) * p);
        }

        // Normal via tetrahedron — 4 calls instead of 6
        vec3 calcNormal(vec3 p) {
          float h = 0.001;
          vec2 k = vec2(1.0, -1.0);
          return normalize(
            k.xyy * map(p + k.xyy * h).x +
            k.yyx * map(p + k.yyx * h).x +
            k.yxy * map(p + k.yxy * h).x +
            k.xxx * map(p + k.xxx * h).x
          );
        }

        // AO — 3 samples
        float calcAO(vec3 pos, vec3 nor) {
          float occ = 0.0;
          float sca = 1.0;
          for (int i = 0; i < 3; i++) {
            float h = 0.01 + 0.05 * float(i);
            float d = map(pos + h * nor).x;
            occ += (h - d) * sca;
            sca *= 0.7;
          }
          return clamp(1.0 - 3.0 * occ, 0.0, 1.0);
        }

        // Pseudo-random for stars
        float hash(vec2 p) {
          return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
        }

        void main() {
          vec2 uv = (gl_FragCoord.xy - 0.5 * uResolution) / min(uResolution.x, uResolution.y);

          // Camera
          float zoom = 6.0 / uZoom;
          vec3 ro = vec3(0.0, 0.0, zoom);
          vec3 rd = normalize(vec3(uv, -1.0));

          // Background — deep space
          vec3 col = vec3(0.01, 0.01, 0.02);

          // Stars
          vec2 starUv = gl_FragCoord.xy / 3.0;
          float star = hash(floor(starUv));
          if (star > 0.997) {
            float twinkle = 0.5 + 0.5 * sin(uTime * 2.0 + star * 100.0);
            col += vec3(0.4, 0.45, 0.6) * twinkle * smoothstep(0.997, 1.0, star);
          }

          // Subtle radial glow at center
          float centerGlow = exp(-2.5 * dot(uv, uv));
          col += vec3(0.03, 0.04, 0.12) * centerGlow;

          // Raymarch — larger steps for speed
          float t = 0.0;
          float minDist = 1e10;
          vec2 res;

          for (int i = 0; i < MAX_STEPS; i++) {
            vec3 p = ro + rd * t;
            res = map(p);
            float d = res.x;

            minDist = min(minDist, d);

            if (d < MIN_DIST || t > MAX_DIST) break;
            t += d * 0.85;
          }

          if (t < MAX_DIST) {
            vec3 p = ro + rd * t;
            vec3 n = calcNormal(p);

            // Lighting
            vec3 lightDir = normalize(vec3(0.6, 0.8, 0.5));
            float diff = max(dot(n, lightDir), 0.0);
            float diff2 = max(dot(n, normalize(vec3(-0.4, -0.3, 0.7))), 0.0);

            // Specular
            vec3 viewDir = normalize(ro - p);
            float spec = pow(max(dot(n, normalize(lightDir + viewDir)), 0.0), 32.0);

            // AO
            float ao = calcAO(p, n);

            // Fractal coloring via orbit trap
            vec3 baseCol = palette(res.y * 0.15 + uTime * 0.02);

            // Rim light
            float rim = pow(1.0 - max(dot(viewDir, n), 0.0), 3.0);

            // Composite
            col = baseCol * (0.3 + 0.75 * diff + 0.3 * diff2);
            col += vec3(0.4, 0.45, 0.9) * spec * 0.6;
            col += vec3(0.35, 0.4, 0.85) * rim * 0.4;
            col *= ao;

            // Depth fog
            float fog = 1.0 - exp(-0.008 * t * t);
            col = mix(col, vec3(0.02, 0.02, 0.05), fog);
          } else {
            // Glow halo
            float glow = exp(-12.0 * minDist);
            col += vec3(0.06, 0.08, 0.18) * glow;
          }

          // Vignette
          vec2 vUv = gl_FragCoord.xy / uResolution;
          float vig = 1.0 - 0.4 * dot((vUv - 0.5) * 1.4, (vUv - 0.5) * 1.4);
          col *= vig;

          // Tone mapping
          col *= 1.3;
          col = col / (1.0 + col);
          col = pow(col, vec3(0.8));

          gl_FragColor = vec4(col, 1.0);
        }
      `;

      const uniforms = {
        uResolution: { value: new THREE.Vector2(
          window.innerWidth * getEffectiveDpr(),
          window.innerHeight * getEffectiveDpr()
        )},
        uTime: { value: 0.0 },
        uMouse: { value: new THREE.Vector2(0.2, 0.25) },
        uZoom: { value: 1.0 },
      };

      const geometry = new THREE.PlaneGeometry(2, 2);
      const material = new THREE.ShaderMaterial({
        vertexShader,
        fragmentShader,
        uniforms,
      });

      scene.add(new THREE.Mesh(geometry, material));

      // ─── Interaction ───
      let isDragging = false;
      let prevX = 0, prevY = 0;
      let autoAngleY = 0.25;
      let autoAngleX = 0.2;
      let targetAngleY = autoAngleY;
      let targetAngleX = autoAngleX;
      let lastInteraction = 0;
      let hasInteracted = false;

      canvas.addEventListener('mousedown', (e) => {
        isDragging = true;
        prevX = e.clientX;
        prevY = e.clientY;
        hasInteracted = true;
        lastInteraction = performance.now();
      });

      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const dx = (e.clientX - prevX) * 0.005;
        const dy = (e.clientY - prevY) * 0.005;
        targetAngleY += dx;
        targetAngleX += dy;
        targetAngleX = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, targetAngleX));
        prevX = e.clientX;
        prevY = e.clientY;
      });

      window.addEventListener('mouseup', () => { isDragging = false; });

      // Touch support
      canvas.addEventListener('touchstart', (e) => {
        isDragging = true;
        prevX = e.touches[0].clientX;
        prevY = e.touches[0].clientY;
        hasInteracted = true;
        lastInteraction = performance.now();
      }, { passive: true });

      canvas.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const dx = (e.touches[0].clientX - prevX) * 0.005;
        const dy = (e.touches[0].clientY - prevY) * 0.005;
        targetAngleY += dx;
        targetAngleX += dy;
        targetAngleX = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, targetAngleX));
        prevX = e.touches[0].clientX;
        prevY = e.touches[0].clientY;
      }, { passive: true });

      canvas.addEventListener('touchend', () => { isDragging = false; });

      // Zoom
      canvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        uniforms.uZoom.value *= e.deltaY > 0 ? 0.95 : 1.05;
        uniforms.uZoom.value = Math.max(0.3, Math.min(5.0, uniforms.uZoom.value));
        hasInteracted = true;
        lastInteraction = performance.now();
      }, { passive: false });

      // ─── Resize ───
      function updateSize() {
        const dpr = getEffectiveDpr();
        renderer.setPixelRatio(dpr);
        renderer.setSize(window.innerWidth, window.innerHeight);
        uniforms.uResolution.value.set(window.innerWidth * dpr, window.innerHeight * dpr);
      }
      window.addEventListener('resize', updateSize);

      // ─── Hint fade ───
      const hintEl = document.getElementById('hint')!;
      setTimeout(() => {
        hintEl.style.opacity = '0';
      }, 5000);

      // ─── Animate with adaptive quality ───
      const clock = new THREE.Clock();
      let frameTimes: number[] = [];
      let lastFrameTime = performance.now();
      let scaleUpdateTimer = 0;

      function animate() {
        requestAnimationFrame(animate);

        const now = performance.now();
        const dt = now - lastFrameTime;
        lastFrameTime = now;

        // Track frame times (rolling window of 20 frames)
        frameTimes.push(dt);
        if (frameTimes.length > 20) frameTimes.shift();

        // Adapt resolution every 30 frames
        scaleUpdateTimer++;
        if (scaleUpdateTimer >= 30 && frameTimes.length >= 10) {
          scaleUpdateTimer = 0;
          const avgFrameTime = frameTimes.reduce((a, b) => a + b) / frameTimes.length;

          if (avgFrameTime > 33) {
            // Below 30 fps — scale down
            targetScale = Math.max(0.4, targetScale - 0.1);
          } else if (avgFrameTime < 20 && targetScale < 1.0) {
            // Above 50 fps — scale up
            targetScale = Math.min(1.0, targetScale + 0.05);
          }
        }

        // Smoothly transition scale
        if (Math.abs(currentScale - targetScale) > 0.01) {
          currentScale += (targetScale - currentScale) * 0.1;
          updateSize();
        }

        const elapsed = clock.getElapsedTime();
        uniforms.uTime.value = elapsed;

        // Auto-rotate when idle
        const timeSinceInteraction = now - lastInteraction;
        if (!isDragging && timeSinceInteraction > 3000) {
          targetAngleY += 0.0008;
        }

        // Smooth lerp
        autoAngleY += (targetAngleY - autoAngleY) * 0.06;
        autoAngleX += (targetAngleX - autoAngleX) * 0.06;
        uniforms.uMouse.value.set(autoAngleX, autoAngleY);

        renderer.render(scene, camera);
      }

      animate();
    </script>
  </body>
</html>
