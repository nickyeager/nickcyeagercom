---
const title = 'Nick C. Yeager';
const description = 'AI Solutions Architect. Speaker. Builder.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { overflow: hidden; background: #050508; }

      canvas#fractal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: block;
      }

      .overlay {
        position: fixed;
        bottom: 32px;
        left: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        color: #C8C8C8;
        line-height: 1.8;
        pointer-events: auto;
        padding: 20px 24px;
        background: rgba(5, 5, 8, 0.55);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(140, 160, 220, 0.1);
        border-radius: 6px;
      }

      .overlay .name {
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        font-weight: 600;
        color: #e0e0e0;
        letter-spacing: 0.02em;
        margin-bottom: 2px;
      }

      .overlay .tagline {
        font-size: clamp(0.65rem, 1.2vw, 0.78rem);
        color: #585858;
        margin-bottom: 16px;
        letter-spacing: 0.04em;
      }

      .overlay .links {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .overlay a {
        font-size: clamp(0.7rem, 1.1vw, 0.82rem);
        color: #8EAADC;
        text-decoration: none;
        transition: color 0.3s ease, text-shadow 0.3s ease;
        width: fit-content;
      }

      .overlay a:hover {
        color: #B8D0FF;
        text-shadow: 0 0 12px rgba(140, 170, 220, 0.4);
      }

      .overlay .nav-links {
        display: flex;
        gap: 16px;
        margin-top: 16px;
        padding-top: 12px;
        border-top: 1px solid rgba(140, 160, 220, 0.15);
      }

      .overlay .nav-links a {
        color: #585858;
        font-size: clamp(0.6rem, 1vw, 0.72rem);
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .overlay .nav-links a:hover {
        color: #C8C8C8;
        text-shadow: none;
      }

      .hint {
        position: fixed;
        bottom: 32px;
        right: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        color: #333;
        letter-spacing: 0.08em;
        transition: opacity 0.8s ease;
      }

      @media (max-width: 640px) {
        .overlay { bottom: 20px; left: 20px; }
        .hint { bottom: 20px; right: 20px; }
      }
    </style>
  </head>
  <body>
    <canvas id="fractal"></canvas>

    <div class="overlay">
      <div class="name">Nick C. Yeager</div>
      <div class="tagline">AI Solutions Architect / Speaker / Tucson, AZ</div>
      <div class="links">
        <a href="https://github.com/nickyeager" target="_blank" rel="noopener">github</a>
        <a href="https://www.linkedin.com/in/nicholas-yeager/" target="_blank" rel="noopener">linkedin</a>
        <a href="mailto:yeag123@gmail.com">yeag123@gmail.com</a>
      </div>
      <div class="nav-links">
        <a href="/about">about</a>
        <a href="/blog">blog</a>
        <a href="/talks">talks</a>
        <a href="/fractal">what is this?</a>
      </div>
    </div>

    <div class="hint" id="hint">drag to rotate · scroll to zoom</div>

    <script>
      import * as THREE from 'three';

      // ─── Adaptive Quality ───
      const baseDpr = Math.min(window.devicePixelRatio, 1.0);
      let currentScale = 0.35;
      let targetScale = 0.35;
      function getEffectiveDpr() { return baseDpr * currentScale; }

      // ─── Setup ───
      const canvas = document.getElementById('fractal') as HTMLCanvasElement;
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, powerPreference: 'low-power' });
      renderer.setPixelRatio(getEffectiveDpr());
      renderer.setSize(window.innerWidth, window.innerHeight);

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

      // ─── Fractal Shader (optimized: no AO, 6 iters, 60 steps, single light) ───
      const vertexShader = `void main() { gl_Position = vec4(position, 1.0); }`;

      const fragmentShader = `
        precision mediump float;

        uniform vec2 uResolution;
        uniform float uTime;
        uniform vec2 uMouse;
        uniform float uZoom;

        #define MAX_STEPS 60
        #define MAX_DIST 14.0
        #define MIN_DIST 0.002
        #define ITERATIONS 6

        vec3 palette(float t) {
          return vec3(0.28, 0.3, 0.58) + vec3(0.18, 0.2, 0.35) * cos(6.28318 * (t + vec3(0.0, 0.05, 0.15)));
        }

        vec2 mandelbox(vec3 pos) {
          float scale = -1.77 + sin(uTime * 0.08) * 0.05;
          vec3 z = pos;
          float dz = 1.0;
          float trap = 1e10;
          float as = abs(scale);

          for (int i = 0; i < ITERATIONS; i++) {
            z = clamp(z, -1.0, 1.0) * 2.0 - z;
            float r2 = dot(z, z);
            if (r2 < 0.25) { z *= 4.0; dz *= 4.0; }
            else if (r2 < 1.0) { float t = 1.0 / r2; z *= t; dz *= t; }
            z = scale * z + pos;
            dz = dz * as + 1.0;
            trap = min(trap, dot(z, z));
          }

          return vec2(length(z) / abs(dz), sqrt(trap));
        }

        mat3 rotateXY(vec2 a) {
          float cx = cos(a.x), sx = sin(a.x), cy = cos(a.y), sy = sin(a.y);
          return mat3(cy,0,sy, sx*sy,cx,-sx*cy, -cx*sy,sx,cx*cy);
        }

        vec2 map(vec3 p) { return mandelbox(rotateXY(uMouse) * p); }

        vec3 calcNormal(vec3 p) {
          vec2 k = vec2(1,-1);
          float h = 0.002;
          return normalize(
            k.xyy*map(p+k.xyy*h).x + k.yyx*map(p+k.yyx*h).x +
            k.yxy*map(p+k.yxy*h).x + k.xxx*map(p+k.xxx*h).x);
        }

        float hash(vec2 p) { return fract(sin(dot(p, vec2(127.1,311.7)))*43758.5453); }

        void main() {
          vec2 uv = (gl_FragCoord.xy - 0.5*uResolution) / min(uResolution.x, uResolution.y);

          vec3 ro = vec3(0, 0, 6.0/uZoom);
          vec3 rd = normalize(vec3(uv, -1.0));

          // Background
          vec3 col = vec3(0.01, 0.01, 0.02);
          vec2 starUv = gl_FragCoord.xy / 3.0;
          float star = hash(floor(starUv));
          if (star > 0.998) col += vec3(0.3,0.35,0.5) * (0.5+0.5*sin(uTime*2.0+star*100.0));
          col += vec3(0.03,0.04,0.12) * exp(-2.5*dot(uv,uv));

          // Raymarch
          float t = 0.0;
          float minDist = 1e10;
          vec2 res;
          for (int i = 0; i < MAX_STEPS; i++) {
            res = map(ro + rd*t);
            minDist = min(minDist, res.x);
            if (res.x < MIN_DIST || t > MAX_DIST) break;
            t += res.x * 0.9;
          }

          if (t < MAX_DIST) {
            vec3 p = ro + rd*t;
            vec3 n = calcNormal(p);
            vec3 l = normalize(vec3(0.6, 0.8, 0.5));
            vec3 v = normalize(ro - p);

            float diff = max(dot(n, l), 0.0);
            float spec = pow(max(dot(n, normalize(l+v)), 0.0), 24.0);
            float rim = pow(1.0-max(dot(v,n),0.0), 2.5);

            vec3 baseCol = palette(res.y * 0.15 + uTime * 0.02);
            col = baseCol * (0.35 + 0.75*diff);
            col += vec3(0.4, 0.45, 0.9) * spec * 0.5;
            col += vec3(0.3, 0.35, 0.7) * rim * 0.3;
            col = mix(col, vec3(0.02,0.02,0.05), 1.0-exp(-0.008*t*t));
          } else {
            col += vec3(0.06,0.08,0.18) * exp(-12.0*minDist);
          }

          // Vignette + tonemap
          vec2 vUv = gl_FragCoord.xy / uResolution;
          col *= 1.0 - 0.4*dot((vUv-0.5)*1.4, (vUv-0.5)*1.4);
          col *= 1.3;
          col = col/(1.0+col);
          col = pow(col, vec3(0.8));

          gl_FragColor = vec4(col, 1.0);
        }
      `;

      const uniforms = {
        uResolution: { value: new THREE.Vector2(
          window.innerWidth * getEffectiveDpr(),
          window.innerHeight * getEffectiveDpr()
        )},
        uTime: { value: 0.0 },
        uMouse: { value: new THREE.Vector2(0.2, 0.25) },
        uZoom: { value: 1.0 },
      };

      scene.add(new THREE.Mesh(
        new THREE.PlaneGeometry(2, 2),
        new THREE.ShaderMaterial({ vertexShader, fragmentShader, uniforms })
      ));

      // ─── Interaction ───
      let isDragging = false;
      let prevX = 0, prevY = 0;
      let autoAngleY = 0.25, autoAngleX = 0.2;
      let targetAngleY = autoAngleY, targetAngleX = autoAngleX;
      let lastInteraction = 0;
      let needsRender = true;

      function markDirty() { needsRender = true; lastInteraction = performance.now(); }

      canvas.addEventListener('mousedown', (e) => {
        isDragging = true; prevX = e.clientX; prevY = e.clientY; markDirty();
      });
      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        targetAngleY += (e.clientX - prevX) * 0.005;
        targetAngleX += (e.clientY - prevY) * 0.005;
        targetAngleX = Math.max(-Math.PI/2, Math.min(Math.PI/2, targetAngleX));
        prevX = e.clientX; prevY = e.clientY; markDirty();
      });
      window.addEventListener('mouseup', () => { isDragging = false; });

      canvas.addEventListener('touchstart', (e) => {
        isDragging = true; prevX = e.touches[0].clientX; prevY = e.touches[0].clientY; markDirty();
      }, { passive: true });
      canvas.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        targetAngleY += (e.touches[0].clientX - prevX) * 0.005;
        targetAngleX += (e.touches[0].clientY - prevY) * 0.005;
        targetAngleX = Math.max(-Math.PI/2, Math.min(Math.PI/2, targetAngleX));
        prevX = e.touches[0].clientX; prevY = e.touches[0].clientY; markDirty();
      }, { passive: true });
      canvas.addEventListener('touchend', () => { isDragging = false; });

      canvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        uniforms.uZoom.value *= e.deltaY > 0 ? 0.95 : 1.05;
        uniforms.uZoom.value = Math.max(0.3, Math.min(5.0, uniforms.uZoom.value));
        markDirty();
      }, { passive: false });

      // ─── Resize ───
      function updateSize() {
        const dpr = getEffectiveDpr();
        renderer.setPixelRatio(dpr);
        renderer.setSize(window.innerWidth, window.innerHeight);
        uniforms.uResolution.value.set(window.innerWidth * dpr, window.innerHeight * dpr);
      }
      window.addEventListener('resize', () => { updateSize(); markDirty(); });

      // ─── Hint fade ───
      setTimeout(() => { document.getElementById('hint')!.style.opacity = '0'; }, 5000);

      // ─── Animation loop: 30fps cap + dirty rendering + adaptive quality ───
      const clock = new THREE.Clock();
      let frameTimes: number[] = [];
      let lastRenderTime = 0;
      let frameCount = 0;
      const FRAME_BUDGET = 33; // ~30fps cap

      function animate() {
        requestAnimationFrame(animate);
        const now = performance.now();

        // 30fps cap — skip if too soon
        if (now - lastRenderTime < FRAME_BUDGET) return;

        // Auto-rotate (slow) — marks dirty every 3rd frame only
        const idle = !isDragging && (now - lastInteraction > 3000);
        if (idle && frameCount % 3 === 0) {
          targetAngleY += 0.0024; // 3x because every 3rd frame
          needsRender = true;
        }

        // Smooth lerp — only if still converging
        const dY = targetAngleY - autoAngleY;
        const dX = targetAngleX - autoAngleX;
        if (Math.abs(dY) > 0.0001 || Math.abs(dX) > 0.0001) {
          autoAngleY += dY * 0.06;
          autoAngleX += dX * 0.06;
          needsRender = true;
        }

        if (!needsRender) { frameCount++; return; }

        const renderStart = performance.now();

        uniforms.uTime.value = clock.getElapsedTime();
        uniforms.uMouse.value.set(autoAngleX, autoAngleY);
        renderer.render(scene, camera);

        const renderTime = performance.now() - renderStart;
        lastRenderTime = now;
        needsRender = false;
        frameCount++;

        // Adaptive quality based on render time
        frameTimes.push(renderTime);
        if (frameTimes.length > 15) frameTimes.shift();
        if (frameCount % 20 === 0 && frameTimes.length >= 8) {
          const avg = frameTimes.reduce((a, b) => a + b) / frameTimes.length;
          if (avg > 40) targetScale = Math.max(0.2, targetScale - 0.08);
          else if (avg < 15 && targetScale < 0.8) targetScale = Math.min(0.8, targetScale + 0.03);

          if (Math.abs(currentScale - targetScale) > 0.01) {
            currentScale += (targetScale - currentScale) * 0.15;
            updateSize();
            needsRender = true;
          }
        }
      }

      animate();
    </script>
  </body>
</html>
