---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

const talks = (await getCollection('talks'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Base>
  <section class="mb-20">
    <h1 class="text-terminal-text text-lg font-medium mb-1">Nick C. Yeager</h1>
    <p class="text-terminal-muted text-sm mb-6">AI Solutions Architect / Speaker / Tucson, AZ</p>
    <div class="text-sm leading-relaxed text-terminal-text/80 space-y-3 font-sans max-w-xl">
      <p>I help companies ship AI that works. Previously built an industry-first AI pharmaceutical assistant at ScriptSave, led engineering across healthcare, finance, and insurance. Co-founded a venture-backed startup.</p>
      <p>Now focused on AI consulting, giving talks, and writing about the messy reality of putting LLMs into production.</p>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="mb-16">
      <h2 class="text-xs text-terminal-muted uppercase tracking-widest mb-6">recent writing</h2>
      <ul class="space-y-3">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group flex items-baseline gap-3 cursor-pointer">
              <span class="text-terminal-muted text-xs font-mono shrink-0">{post.data.date}</span>
              <span class="text-terminal-text/90 group-hover:text-terminal-green transition-colors duration-200">
                {post.data.title}
              </span>
            </a>
          </li>
        ))}
      </ul>
      <a href="/blog" class="inline-block mt-4 text-xs text-terminal-muted hover:text-terminal-text transition-colors duration-200 cursor-pointer">
        all posts &rarr;
      </a>
    </section>
  )}

  {talks.length > 0 && (
    <section>
      <h2 class="text-xs text-terminal-muted uppercase tracking-widest mb-6">recent talks</h2>
      <ul class="space-y-4">
        {talks.map((talk) => (
          <li>
            <a href={`/talks/${talk.id}`} class="group block cursor-pointer">
              <div class="flex items-baseline gap-3">
                <span class="text-terminal-muted text-xs font-mono shrink-0">{talk.data.date}</span>
                <span class="text-terminal-text/90 group-hover:text-terminal-green transition-colors duration-200">
                  {talk.data.title}
                </span>
              </div>
              <div class="text-xs text-terminal-muted mt-0.5 ml-[calc(10ch+0.75rem)]">
                {talk.data.event}
                {talk.data.video && <span class="text-terminal-dim ml-2">[video]</span>}
                {talk.data.slides && <span class="text-terminal-dim ml-2">[slides]</span>}
              </div>
            </a>
          </li>
        ))}
      </ul>
      <a href="/talks" class="inline-block mt-4 text-xs text-terminal-muted hover:text-terminal-text transition-colors duration-200 cursor-pointer">
        all talks &rarr;
      </a>
    </section>
  )}
</Base>
