---
const title = 'Nick C. Yeager';
const description = 'AI Solutions Architect. Speaker. Builder.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Nick C. Yeager" />
    <link rel="canonical" href="https://nickcyeager.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://nickcyeager.com/" />
    <meta property="og:site_name" content="Nick C. Yeager" />
    <meta property="og:image" content="https://nickcyeager.com/og-image.png" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://nickcyeager.com/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Nick C. Yeager",
      "url": "https://nickcyeager.com",
      "jobTitle": "AI Solutions Architect",
      "description": "AI Solutions Architect, speaker, and builder based in Tucson, AZ.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Tucson",
        "addressRegion": "AZ",
        "addressCountry": "US"
      },
      "sameAs": [
        "https://github.com/nickyeager",
        "https://www.linkedin.com/in/nicholas-yeager/"
      ]
    }
    </script>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { overflow: hidden; background: #050508; }

      canvas#fractal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: block;
      }

      .overlay {
        position: fixed;
        bottom: 32px;
        left: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        color: #C8C8C8;
        line-height: 1.8;
        pointer-events: auto;
        padding: 20px 24px;
        background: rgba(5, 5, 8, 0.55);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(140, 160, 220, 0.1);
        border-radius: 6px;
      }

      .overlay .name {
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        font-weight: 600;
        color: #e0e0e0;
        letter-spacing: 0.02em;
        margin-bottom: 2px;
      }

      .overlay .tagline {
        font-size: clamp(0.65rem, 1.2vw, 0.78rem);
        color: #585858;
        margin-bottom: 16px;
        letter-spacing: 0.04em;
      }

      .overlay .links {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .overlay a {
        font-size: clamp(0.7rem, 1.1vw, 0.82rem);
        color: #8EAADC;
        text-decoration: none;
        transition: color 0.3s ease, text-shadow 0.3s ease;
        width: fit-content;
      }

      .overlay a:hover {
        color: #B8D0FF;
        text-shadow: 0 0 12px rgba(140, 170, 220, 0.4);
      }

      .overlay .nav-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 16px;
        padding-top: 14px;
        border-top: 1px solid rgba(140, 160, 220, 0.15);
      }

      .overlay .nav-links a {
        color: #9AB0D8;
        font-size: clamp(0.68rem, 1.1vw, 0.78rem);
        letter-spacing: 0.06em;
        text-transform: none;
        padding: 6px 14px;
        border: 1px solid rgba(140, 160, 220, 0.2);
        border-radius: 4px;
        background: rgba(140, 160, 220, 0.05);
        transition: all 0.25s ease;
      }

      .overlay .nav-links a:hover {
        color: #D0DFFF;
        background: rgba(140, 160, 220, 0.15);
        border-color: rgba(140, 160, 220, 0.4);
        text-shadow: 0 0 8px rgba(140, 170, 220, 0.3);
      }

      .hint {
        position: fixed;
        bottom: 32px;
        right: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        color: #333;
        letter-spacing: 0.08em;
        transition: opacity 0.8s ease;
      }

      @media (max-width: 640px) {
        .overlay {
          bottom: 16px;
          left: 16px;
          right: 16px;
          padding: 16px 18px;
        }
        .overlay .nav-links {
          gap: 6px;
        }
        .overlay .nav-links a {
          padding: 8px 14px;
          font-size: 0.72rem;
        }
        .hint { bottom: 16px; right: 16px; }
      }
    </style>
  </head>
  <body>
    <canvas id="fractal"></canvas>

    <div class="overlay">
      <div class="name">Nick C. Yeager</div>
      <div class="tagline">AI Solutions Architect / Speaker / Tucson, AZ</div>
      <div class="links">
        <a href="https://github.com/nickyeager" target="_blank" rel="noopener">github</a>
        <a href="https://www.linkedin.com/in/nicholas-yeager/" target="_blank" rel="noopener">linkedin</a>
        <a href="mailto:yeag123@gmail.com">yeag123@gmail.com</a>
      </div>
      <div class="nav-links">
        <a href="/about">About Me</a>
        <a href="/blog">Blog</a>
        <a href="/talks">Talks</a>
        <a href="/fractal">About This Fractal</a>
      </div>
    </div>

    <div class="hint" id="hint">drag to rotate · scroll to zoom</div>

    <script>
      import * as THREE from 'three';

      // ─── Adaptive Quality ───
      const baseDpr = Math.min(window.devicePixelRatio, 1.0);
      let currentScale = 0.35;
      let targetScale = 0.35;
      function getEffectiveDpr() { return baseDpr * currentScale; }

      // ─── Setup ───
      const canvas = document.getElementById('fractal') as HTMLCanvasElement;
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, powerPreference: 'low-power' });
      renderer.setPixelRatio(getEffectiveDpr());
      renderer.setSize(window.innerWidth, window.innerHeight);

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

      // ─── Fractal Shader (v3: rotation uniform, 48 steps, 5 iters, no AO) ───
      const vertexShader = `void main() { gl_Position = vec4(position, 1.0); }`;

      const fragmentShader = `
        precision mediump float;

        uniform vec2 uResolution;
        uniform float uTime;
        uniform float uZoom;
        uniform mat3 uRotation;
        uniform float uScale;

        #define MAX_STEPS 48
        #define MAX_DIST 12.0
        #define MIN_DIST 0.003
        #define ITERATIONS 5

        vec3 palette(float t) {
          return vec3(0.28,0.3,0.58) + vec3(0.18,0.2,0.35)*cos(6.28318*(t+vec3(0,0.05,0.15)));
        }

        float mandelbox(vec3 pos, out float trap) {
          vec3 z = pos;
          float dz = 1.0;
          trap = 1e10;
          float as = abs(uScale);
          for (int i = 0; i < ITERATIONS; i++) {
            z = clamp(z,-1.0,1.0)*2.0-z;
            float r2 = dot(z,z);
            if (r2<0.25){z*=4.0;dz*=4.0;}
            else if(r2<1.0){float t=1.0/r2;z*=t;dz*=t;}
            z = uScale*z+pos;
            dz = dz*as+1.0;
            trap = min(trap, dot(z,z));
          }
          trap = sqrt(trap);
          return length(z)/abs(dz);
        }

        float map(vec3 p, out float trap) { return mandelbox(uRotation*p, trap); }
        float mapD(vec3 p) { float t; return mandelbox(uRotation*p, t); }

        vec3 calcNormal(vec3 p) {
          vec2 k = vec2(1,-1);
          float h = 0.003;
          return normalize(
            k.xyy*mapD(p+k.xyy*h) + k.yyx*mapD(p+k.yyx*h) +
            k.yxy*mapD(p+k.yxy*h) + k.xxx*mapD(p+k.xxx*h));
        }

        float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}

        void main() {
          vec2 uv = (gl_FragCoord.xy-0.5*uResolution)/min(uResolution.x,uResolution.y);
          vec3 ro = vec3(0,0,6.0/uZoom);
          vec3 rd = normalize(vec3(uv,-1.0));

          // Background
          vec3 col = vec3(0.01,0.01,0.02);
          float star = hash(floor(gl_FragCoord.xy/3.0));
          if(star>0.998) col+=vec3(0.3,0.35,0.5)*(0.5+0.5*sin(uTime*2.0+star*100.0));
          col+=vec3(0.03,0.04,0.12)*exp(-2.5*dot(uv,uv));

          // Raymarch
          float t=0.0, minD=1e10, trap;
          float d;
          for(int i=0;i<MAX_STEPS;i++){
            d=map(ro+rd*t, trap);
            minD=min(minD,d);
            if(d<MIN_DIST||t>MAX_DIST)break;
            t+=d*0.95;
          }

          if(t<MAX_DIST){
            vec3 p=ro+rd*t;
            vec3 n=calcNormal(p);
            vec3 l=normalize(vec3(0.6,0.8,0.5));
            vec3 v=normalize(ro-p);
            float diff=max(dot(n,l),0.0);
            float spec=pow(max(dot(n,normalize(l+v)),0.0),20.0);
            float rim=pow(1.0-max(dot(v,n),0.0),2.5);

            col=palette(trap*0.15+uTime*0.02)*(0.35+0.75*diff);
            col+=vec3(0.4,0.45,0.9)*spec*0.5;
            col+=vec3(0.3,0.35,0.7)*rim*0.3;
            col=mix(col,vec3(0.02,0.02,0.05),1.0-exp(-0.01*t*t));
          } else {
            col+=vec3(0.06,0.08,0.18)*exp(-12.0*minD);
          }

          vec2 vUv=gl_FragCoord.xy/uResolution;
          col*=1.0-0.4*dot((vUv-0.5)*1.4,(vUv-0.5)*1.4);
          col*=1.3; col=col/(1.0+col); col=pow(col,vec3(0.8));
          gl_FragColor=vec4(col,1.0);
        }
      `;

      const uniforms = {
        uResolution: { value: new THREE.Vector2(
          window.innerWidth * getEffectiveDpr(),
          window.innerHeight * getEffectiveDpr()
        )},
        uTime: { value: 0.0 },
        uZoom: { value: 1.0 },
        uRotation: { value: new THREE.Matrix3() },
        uScale: { value: -1.77 },
      };

      scene.add(new THREE.Mesh(
        new THREE.PlaneGeometry(2, 2),
        new THREE.ShaderMaterial({ vertexShader, fragmentShader, uniforms })
      ));

      // ─── Interaction ───
      let isDragging = false;
      let prevX = 0, prevY = 0;
      let autoAngleY = 0.25, autoAngleX = 0.2;
      let targetAngleY = autoAngleY, targetAngleX = autoAngleX;
      let lastInteraction = 0;
      let needsRender = true;

      function markDirty() { needsRender = true; lastInteraction = performance.now(); }

      canvas.addEventListener('mousedown', (e) => {
        isDragging = true; prevX = e.clientX; prevY = e.clientY; markDirty();
      });
      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        targetAngleY += (e.clientX - prevX) * 0.005;
        targetAngleX += (e.clientY - prevY) * 0.005;
        targetAngleX = Math.max(-Math.PI/2, Math.min(Math.PI/2, targetAngleX));
        prevX = e.clientX; prevY = e.clientY; markDirty();
      });
      window.addEventListener('mouseup', () => { isDragging = false; });

      canvas.addEventListener('touchstart', (e) => {
        isDragging = true; prevX = e.touches[0].clientX; prevY = e.touches[0].clientY; markDirty();
      }, { passive: true });
      canvas.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        targetAngleY += (e.touches[0].clientX - prevX) * 0.005;
        targetAngleX += (e.touches[0].clientY - prevY) * 0.005;
        targetAngleX = Math.max(-Math.PI/2, Math.min(Math.PI/2, targetAngleX));
        prevX = e.touches[0].clientX; prevY = e.touches[0].clientY; markDirty();
      }, { passive: true });
      canvas.addEventListener('touchend', () => { isDragging = false; });

      canvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        uniforms.uZoom.value *= e.deltaY > 0 ? 0.95 : 1.05;
        uniforms.uZoom.value = Math.max(0.3, Math.min(5.0, uniforms.uZoom.value));
        markDirty();
      }, { passive: false });

      // ─── Resize ───
      function updateSize() {
        const dpr = getEffectiveDpr();
        renderer.setPixelRatio(dpr);
        renderer.setSize(window.innerWidth, window.innerHeight);
        uniforms.uResolution.value.set(window.innerWidth * dpr, window.innerHeight * dpr);
      }
      window.addEventListener('resize', () => { updateSize(); markDirty(); });

      // ─── Hint fade ───
      setTimeout(() => { document.getElementById('hint')!.style.opacity = '0'; }, 5000);

      // ─── Rotation matrix helper (computed in JS, not GPU) ───
      function updateRotationUniform(ax: number, ay: number) {
        const cx = Math.cos(ax), sx = Math.sin(ax);
        const cy = Math.cos(ay), sy = Math.sin(ay);
        uniforms.uRotation.value.set(
          cy, sx*sy, -cx*sy,
          0, cx, sx,
          sy, -sx*cy, cx*cy
        );
      }

      // ─── Animation loop: 30fps cap + dirty + adaptive + progressive refine ───
      const clock = new THREE.Clock();
      let frameTimes: number[] = [];
      let lastRenderTime = 0;
      let frameCount = 0;
      let refineTimer: ReturnType<typeof setTimeout> | null = null;
      const FRAME_BUDGET = 33;

      function renderAtScale(scale: number) {
        currentScale = scale;
        updateSize();
        const elapsed = clock.getElapsedTime();
        uniforms.uTime.value = elapsed;
        uniforms.uScale.value = -1.77 + Math.sin(elapsed * 0.08) * 0.05;
        updateRotationUniform(autoAngleX, autoAngleY);
        renderer.render(scene, camera);
      }

      function scheduleRefine() {
        if (refineTimer) clearTimeout(refineTimer);
        // After 200ms idle, render at higher quality
        refineTimer = setTimeout(() => {
          const hi = Math.min(targetScale * 1.8, 0.7);
          if (hi > currentScale + 0.05) {
            renderAtScale(hi);
          }
        }, 200);
      }

      function animate() {
        requestAnimationFrame(animate);
        const now = performance.now();

        if (now - lastRenderTime < FRAME_BUDGET) return;

        // Auto-rotate — every 4th eligible frame
        const idle = !isDragging && (now - lastInteraction > 3000);
        if (idle && frameCount % 4 === 0) {
          targetAngleY += 0.003;
          needsRender = true;
        }

        // Smooth lerp
        const dY = targetAngleY - autoAngleY;
        const dX = targetAngleX - autoAngleX;
        if (Math.abs(dY) > 0.0001 || Math.abs(dX) > 0.0001) {
          autoAngleY += dY * 0.06;
          autoAngleX += dX * 0.06;
          needsRender = true;
        }

        if (!needsRender) { frameCount++; return; }

        const renderStart = performance.now();
        renderAtScale(targetScale);
        const renderTime = performance.now() - renderStart;

        lastRenderTime = now;
        needsRender = false;
        frameCount++;

        // Schedule a higher-quality refine pass
        scheduleRefine();

        // Adaptive quality
        frameTimes.push(renderTime);
        if (frameTimes.length > 12) frameTimes.shift();
        if (frameCount % 15 === 0 && frameTimes.length >= 6) {
          const avg = frameTimes.reduce((a, b) => a + b) / frameTimes.length;
          if (avg > 35) targetScale = Math.max(0.2, targetScale - 0.06);
          else if (avg < 12 && targetScale < 0.6) targetScale = Math.min(0.6, targetScale + 0.02);
        }
      }

      animate();
    </script>
  </body>
</html>
