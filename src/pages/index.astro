---
const title = 'Nick C. Yeager';
const description = 'AI Solutions Architect. Speaker. Builder.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Nick C. Yeager" />
    <link rel="canonical" href="https://nickcyeager.com/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://nickcyeager.com/" />
    <meta property="og:site_name" content="Nick C. Yeager" />
    <meta property="og:image" content="https://nickcyeager.com/og-image.png" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://nickcyeager.com/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <!-- JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Nick C. Yeager",
      "url": "https://nickcyeager.com",
      "jobTitle": "AI Solutions Architect",
      "description": "AI Solutions Architect, speaker, and builder based in Tucson, AZ.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Tucson",
        "addressRegion": "AZ",
        "addressCountry": "US"
      },
      "sameAs": [
        "https://github.com/nickyeager",
        "https://www.linkedin.com/in/nicholas-yeager/"
      ]
    }
    </script>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { overflow: hidden; background: #050508; }

      canvas#fractal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: block;
      }

      .overlay {
        position: fixed;
        bottom: 32px;
        left: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        color: #C8C8C8;
        line-height: 1.8;
        pointer-events: auto;
        padding: 20px 24px;
        background: rgba(5, 5, 8, 0.55);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(140, 160, 220, 0.1);
        border-radius: 6px;
      }

      .overlay .name {
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        font-weight: 600;
        color: #e0e0e0;
        letter-spacing: 0.02em;
        margin-bottom: 2px;
      }

      .overlay .tagline {
        font-size: clamp(0.65rem, 1.2vw, 0.78rem);
        color: #585858;
        margin-bottom: 16px;
        letter-spacing: 0.04em;
      }

      .overlay .links {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .overlay a {
        font-size: clamp(0.7rem, 1.1vw, 0.82rem);
        color: #8EAADC;
        text-decoration: none;
        transition: color 0.3s ease, text-shadow 0.3s ease;
        width: fit-content;
      }

      .overlay a:hover {
        color: #B8D0FF;
        text-shadow: 0 0 12px rgba(140, 170, 220, 0.4);
      }

      .overlay .nav-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 16px;
        padding-top: 14px;
        border-top: 1px solid rgba(140, 160, 220, 0.15);
      }

      .overlay .nav-links a {
        color: #9AB0D8;
        font-size: clamp(0.68rem, 1.1vw, 0.78rem);
        letter-spacing: 0.06em;
        text-transform: none;
        padding: 6px 14px;
        border: 1px solid rgba(140, 160, 220, 0.2);
        border-radius: 4px;
        background: rgba(140, 160, 220, 0.05);
        transition: all 0.25s ease;
      }

      .overlay .nav-links a:hover {
        color: #D0DFFF;
        background: rgba(140, 160, 220, 0.15);
        border-color: rgba(140, 160, 220, 0.4);
        text-shadow: 0 0 8px rgba(140, 170, 220, 0.3);
      }

      .hint {
        position: fixed;
        bottom: 32px;
        right: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        color: #333;
        letter-spacing: 0.08em;
        transition: opacity 0.8s ease;
      }

      @media (max-width: 640px) {
        .overlay {
          bottom: 16px;
          left: 16px;
          right: 16px;
          padding: 16px 18px;
        }
        .overlay .nav-links {
          gap: 6px;
        }
        .overlay .nav-links a {
          padding: 8px 14px;
          font-size: 0.72rem;
        }
        .hint { bottom: 16px; right: 16px; }
      }
    </style>
  </head>
  <body>
    <canvas id="fractal"></canvas>

    <div class="overlay">
      <div class="name">Nick C. Yeager</div>
      <div class="tagline">AI Solutions Architect / Speaker / Tucson, AZ</div>
      <div class="links">
        <a href="https://github.com/nickyeager" target="_blank" rel="noopener">github</a>
        <a href="https://www.linkedin.com/in/nicholas-yeager/" target="_blank" rel="noopener">linkedin</a>
        <a href="mailto:yeag123@gmail.com">yeag123@gmail.com</a>
      </div>
      <div class="nav-links">
        <a href="/about">About Me</a>
        <a href="/projects">Projects</a>
        <a href="/blog">Blog</a>
        <a href="/talks">Talks</a>
      </div>
    </div>

    <script>
      import * as THREE from 'three';

      // ─── Setup ───
      const canvas = document.getElementById('fractal') as HTMLCanvasElement;
      const dpr = Math.min(window.devicePixelRatio, 2);
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: false });
      renderer.setPixelRatio(dpr);
      renderer.setSize(window.innerWidth, window.innerHeight);

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

      // ─── Topographic Lines Shader ───
      const vertexShader = `void main() { gl_Position = vec4(position, 1.0); }`;

      const fragmentShader = `
        precision highp float;

        uniform vec2 uResolution;
        uniform float uTime;
        uniform vec2 uMouse;

        // Smooth value noise
        float hash(vec2 p) {
          return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
        }

        float vnoise(vec2 p) {
          vec2 i = floor(p), f = fract(p);
          f = f * f * f * (f * (f * 6.0 - 15.0) + 10.0); // quintic smoothstep
          return mix(
            mix(hash(i), hash(i + vec2(1, 0)), f.x),
            mix(hash(i + vec2(0, 1)), hash(i + vec2(1, 1)), f.x),
            f.y
          );
        }

        float fbm(vec2 p) {
          float v = 0.0, a = 0.5;
          mat2 rot = mat2(0.866, 0.5, -0.5, 0.866); // 30deg rotation
          for (int i = 0; i < 6; i++) {
            v += a * vnoise(p);
            p = rot * p * 2.0;
            a *= 0.5;
          }
          return v;
        }

        void main() {
          vec2 uv = gl_FragCoord.xy / uResolution;
          float aspect = uResolution.x / uResolution.y;
          vec2 st = vec2(uv.x * aspect, uv.y);

          float t = uTime * 0.04;

          // Subtle mouse parallax on the noise field
          vec2 offset = (uMouse - 0.5) * 0.3;

          // Multi-octave elevation
          float elevation = fbm(st * 3.5 + vec2(t, t * 0.2) + offset);

          // Contour lines using screen-space derivative for consistent width
          float levels = 25.0;
          float scaledElev = elevation * levels;
          float contour = fract(scaledElev);

          // Use fwidth for resolution-independent line width
          float fw = fwidth(scaledElev);
          float lineWidth = 1.8;
          float line = 1.0 - smoothstep(0.0, fw * lineWidth, contour)
                     + smoothstep(1.0 - fw * lineWidth, 1.0, contour);

          // Major contour every 5 levels
          float majorScaled = elevation * levels / 5.0;
          float majorContour = fract(majorScaled);
          float mfw = fwidth(majorScaled);
          float majorLine = 1.0 - smoothstep(0.0, mfw * 2.5, majorContour)
                          + smoothstep(1.0 - mfw * 2.5, 1.0, majorContour);

          // Color palette (matching site blues/purples)
          vec3 bg = vec3(0.02, 0.02, 0.03);
          vec3 minorCol = vec3(0.22, 0.28, 0.45);   // subtle blue-grey
          vec3 majorCol = vec3(0.45, 0.55, 0.82);    // brighter blue
          vec3 glowCol = vec3(0.55, 0.65, 0.90);     // highlight

          vec3 col = bg;

          // Subtle elevation shading
          col += vec3(0.015, 0.018, 0.04) * elevation;

          // Minor contour lines
          col = mix(col, minorCol * 0.35, line * 0.6);

          // Major contour lines (brighter)
          col = mix(col, majorCol * 0.5, majorLine * 0.8);

          // Subtle glow around major lines
          float glowDist = abs(majorContour - 0.5) * 2.0;
          float glow = exp(-glowDist * glowDist * 8.0) * 0.06;
          col += glowCol * glow;

          // Vignette
          vec2 vig = uv - 0.5;
          col *= 1.0 - 0.35 * dot(vig * 1.3, vig * 1.3);

          // Tone mapping
          col = col / (1.0 + col);
          col = pow(col, vec3(0.9));

          gl_FragColor = vec4(col, 1.0);
        }
      `;

      const uniforms = {
        uResolution: { value: new THREE.Vector2(
          window.innerWidth * dpr,
          window.innerHeight * dpr
        )},
        uTime: { value: 0.0 },
        uMouse: { value: new THREE.Vector2(0.5, 0.5) },
      };

      scene.add(new THREE.Mesh(
        new THREE.PlaneGeometry(2, 2),
        new THREE.ShaderMaterial({ vertexShader, fragmentShader, uniforms,
          extensions: { derivatives: true }
        })
      ));

      // ─── Mouse tracking for parallax ───
      let targetMouse = new THREE.Vector2(0.5, 0.5);
      let currentMouse = new THREE.Vector2(0.5, 0.5);

      window.addEventListener('mousemove', (e) => {
        targetMouse.set(e.clientX / window.innerWidth, 1.0 - e.clientY / window.innerHeight);
      });

      // ─── Resize ───
      window.addEventListener('resize', () => {
        renderer.setSize(window.innerWidth, window.innerHeight);
        uniforms.uResolution.value.set(window.innerWidth * dpr, window.innerHeight * dpr);
      });

      // ─── Animation loop ───
      const clock = new THREE.Clock();

      function animate() {
        requestAnimationFrame(animate);
        uniforms.uTime.value = clock.getElapsedTime();

        // Smooth mouse lerp
        currentMouse.lerp(targetMouse, 0.03);
        uniforms.uMouse.value.copy(currentMouse);

        renderer.render(scene, camera);
      }

      animate();
    </script>
  </body>
</html>
