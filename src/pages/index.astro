---
const title = 'Nick C. Yeager';
const description = 'AI Solutions Architect. Speaker. Builder.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { overflow: hidden; background: #050508; }

      canvas#fractal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: block;
      }

      .overlay {
        position: fixed;
        bottom: 32px;
        left: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        color: #C8C8C8;
        line-height: 1.8;
        pointer-events: auto;
        padding: 20px 24px;
        background: rgba(5, 5, 8, 0.55);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(110, 191, 139, 0.08);
        border-radius: 6px;
      }

      .overlay .name {
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        font-weight: 600;
        color: #e0e0e0;
        letter-spacing: 0.02em;
        margin-bottom: 2px;
      }

      .overlay .tagline {
        font-size: clamp(0.65rem, 1.2vw, 0.78rem);
        color: #585858;
        margin-bottom: 16px;
        letter-spacing: 0.04em;
      }

      .overlay .links {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .overlay a {
        font-size: clamp(0.7rem, 1.1vw, 0.82rem);
        color: #6EBF8B;
        text-decoration: none;
        transition: color 0.3s ease, text-shadow 0.3s ease;
        width: fit-content;
      }

      .overlay a:hover {
        color: #9FFFBE;
        text-shadow: 0 0 12px rgba(110, 191, 139, 0.4);
      }

      .overlay .nav-links {
        display: flex;
        gap: 16px;
        margin-top: 16px;
        padding-top: 12px;
        border-top: 1px solid rgba(110, 191, 139, 0.15);
      }

      .overlay .nav-links a {
        color: #585858;
        font-size: clamp(0.6rem, 1vw, 0.72rem);
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .overlay .nav-links a:hover {
        color: #C8C8C8;
        text-shadow: none;
      }

      .hint {
        position: fixed;
        bottom: 32px;
        right: 32px;
        z-index: 100;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6rem;
        color: #333;
        letter-spacing: 0.08em;
        transition: opacity 0.8s ease;
      }

      @media (max-width: 640px) {
        .overlay { bottom: 20px; left: 20px; }
        .hint { bottom: 20px; right: 20px; }
      }
    </style>
  </head>
  <body>
    <canvas id="fractal"></canvas>

    <div class="overlay">
      <div class="name">Nick C. Yeager</div>
      <div class="tagline">AI Solutions Architect / Speaker / Tucson, AZ</div>
      <div class="links">
        <a href="https://github.com/nickyeager" target="_blank" rel="noopener">github</a>
        <a href="https://www.linkedin.com/in/nicholas-yeager/" target="_blank" rel="noopener">linkedin</a>
        <a href="https://x.com/NickCYeager" target="_blank" rel="noopener">x</a>
        <a href="mailto:yeag123@gmail.com">yeag123@gmail.com</a>
      </div>
      <div class="nav-links">
        <a href="/about">about</a>
        <a href="/blog">blog</a>
        <a href="/talks">talks</a>
      </div>
    </div>

    <div class="hint" id="hint">drag to rotate · scroll to zoom</div>

    <script>
      import * as THREE from 'three';

      // ─── Setup ───
      const canvas = document.getElementById('fractal') as HTMLCanvasElement;
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: false });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(window.innerWidth, window.innerHeight);

      const scene = new THREE.Scene();
      const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

      // ─── Fractal Shader ───
      const vertexShader = `
        void main() {
          gl_Position = vec4(position, 1.0);
        }
      `;

      const fragmentShader = `
        precision highp float;

        uniform vec2 uResolution;
        uniform float uTime;
        uniform vec2 uMouse;
        uniform float uZoom;

        #define MAX_STEPS 120
        #define MAX_DIST 6.0
        #define MIN_DIST 0.0005
        #define ITERATIONS 8

        // Cosine palette — vivid greens & cyans
        vec3 palette(float t) {
          vec3 a = vec3(0.45, 0.6, 0.5);
          vec3 b = vec3(0.4, 0.5, 0.45);
          vec3 c = vec3(1.0, 1.0, 0.8);
          vec3 d = vec3(0.0, 0.25, 0.2);
          return a + b * cos(6.28318 * (c * t + d));
        }

        // Mandelbulb distance estimator
        vec2 mandelbulb(vec3 pos) {
          vec3 z = pos;
          float dr = 1.0;
          float r = 0.0;
          float power = 8.0 + sin(uTime * 0.15) * 0.8;
          float trap = 1e10;

          for (int i = 0; i < ITERATIONS; i++) {
            r = length(z);
            if (r > 2.0) break;

            float theta = acos(z.z / r);
            float phi = atan(z.y, z.x);
            dr = pow(r, power - 1.0) * power * dr + 1.0;

            float zr = pow(r, power);
            theta = theta * power;
            phi = phi * power;

            z = zr * vec3(
              sin(theta) * cos(phi),
              sin(phi) * sin(theta),
              cos(theta)
            ) + pos;

            trap = min(trap, length(z));
          }

          return vec2(0.5 * log(r) * r / dr, trap);
        }

        // Rotation matrix
        mat3 rotateXY(vec2 angle) {
          float cx = cos(angle.x), sx = sin(angle.x);
          float cy = cos(angle.y), sy = sin(angle.y);
          return mat3(
            cy, 0.0, sy,
            sx * sy, cx, -sx * cy,
            -cx * sy, sx, cx * cy
          );
        }

        // Scene SDF
        vec2 map(vec3 p) {
          mat3 rot = rotateXY(uMouse);
          p = rot * p;
          return mandelbulb(p);
        }

        // Soft shadow / AO estimation
        float calcAO(vec3 pos, vec3 nor) {
          float occ = 0.0;
          float sca = 1.0;
          for (int i = 0; i < 5; i++) {
            float h = 0.01 + 0.06 * float(i);
            float d = map(pos + h * nor).x;
            occ += (h - d) * sca;
            sca *= 0.75;
          }
          return clamp(1.0 - 2.5 * occ, 0.0, 1.0);
        }

        // Normal via central differences
        vec3 calcNormal(vec3 p) {
          vec2 e = vec2(0.0005, 0.0);
          return normalize(vec3(
            map(p + e.xyy).x - map(p - e.xyy).x,
            map(p + e.yxy).x - map(p - e.yxy).x,
            map(p + e.yyx).x - map(p - e.yyx).x
          ));
        }

        // Pseudo-random for stars
        float hash(vec2 p) {
          return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
        }

        void main() {
          vec2 uv = (gl_FragCoord.xy - 0.5 * uResolution) / min(uResolution.x, uResolution.y);

          // Camera
          float zoom = 4.5 / uZoom;
          vec3 ro = vec3(0.0, 0.0, zoom);
          vec3 rd = normalize(vec3(uv, -1.2));

          // Background — deep space
          vec3 col = vec3(0.01, 0.01, 0.02);

          // Stars
          vec2 starUv = gl_FragCoord.xy / 3.0;
          float star = hash(floor(starUv));
          if (star > 0.997) {
            float twinkle = 0.5 + 0.5 * sin(uTime * 2.0 + star * 100.0);
            col += vec3(0.4, 0.5, 0.45) * twinkle * smoothstep(0.997, 1.0, star);
          }

          // Subtle radial glow at center
          float centerGlow = exp(-2.5 * dot(uv, uv));
          col += vec3(0.03, 0.08, 0.05) * centerGlow;

          // Raymarch
          float t = 0.0;
          float minDist = 1e10;
          vec2 res;

          for (int i = 0; i < MAX_STEPS; i++) {
            vec3 p = ro + rd * t;
            res = map(p);
            float d = res.x;

            minDist = min(minDist, d);

            if (d < MIN_DIST || t > MAX_DIST) break;
            t += d * 0.7; // slightly conservative for quality
          }

          if (t < MAX_DIST) {
            vec3 p = ro + rd * t;
            vec3 n = calcNormal(p);

            // Lighting
            vec3 lightDir = normalize(vec3(0.6, 0.8, 0.5));
            vec3 lightDir2 = normalize(vec3(-0.4, -0.3, 0.7));
            float diff = max(dot(n, lightDir), 0.0);
            float diff2 = max(dot(n, lightDir2), 0.0);

            // Specular
            vec3 viewDir = normalize(ro - p);
            vec3 halfDir = normalize(lightDir + viewDir);
            float spec = pow(max(dot(n, halfDir), 0.0), 48.0);

            // AO
            float ao = calcAO(p, n);

            // Fractal coloring via orbit trap
            vec3 baseCol = palette(res.y * 0.8 + uTime * 0.03);

            // Rim light — cyan tint
            float rim = 1.0 - max(dot(viewDir, n), 0.0);
            rim = pow(rim, 3.0);

            // Composite — bright
            col = baseCol * (0.35 + 0.8 * diff + 0.35 * diff2);
            col += vec3(0.5, 0.7, 0.55) * spec * 0.7;
            col += vec3(0.4, 0.7, 0.6) * rim * 0.45;
            col *= ao;

            // Depth fog — very light
            float fog = 1.0 - exp(-0.04 * t * t);
            col = mix(col, vec3(0.02, 0.04, 0.03), fog);
          } else {
            // Glow halo around fractal
            float glow = exp(-6.0 * minDist);
            col += vec3(0.1, 0.25, 0.16) * glow;
          }

          // Vignette
          vec2 vUv = gl_FragCoord.xy / uResolution;
          float vig = 1.0 - 0.4 * dot((vUv - 0.5) * 1.4, (vUv - 0.5) * 1.4);
          col *= vig;

          // Tone mapping — bright exposure
          col *= 1.8;
          col = col / (1.0 + col);
          col = pow(col, vec3(0.8));

          gl_FragColor = vec4(col, 1.0);
        }
      `;

      const dpr = Math.min(window.devicePixelRatio, 2);
      const uniforms = {
        uResolution: { value: new THREE.Vector2(window.innerWidth * dpr, window.innerHeight * dpr) },
        uTime: { value: 0.0 },
        uMouse: { value: new THREE.Vector2(0.1, 0.15) },
        uZoom: { value: 1.0 },
      };

      const geometry = new THREE.PlaneGeometry(2, 2);
      const material = new THREE.ShaderMaterial({
        vertexShader,
        fragmentShader,
        uniforms,
      });

      scene.add(new THREE.Mesh(geometry, material));

      // ─── Interaction ───
      let isDragging = false;
      let prevX = 0, prevY = 0;
      let autoAngleY = 0.15;
      let autoAngleX = 0.1;
      let targetAngleY = autoAngleY;
      let targetAngleX = autoAngleX;
      let lastInteraction = 0;
      let hasInteracted = false;

      canvas.addEventListener('mousedown', (e) => {
        isDragging = true;
        prevX = e.clientX;
        prevY = e.clientY;
        hasInteracted = true;
        lastInteraction = performance.now();
      });

      window.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const dx = (e.clientX - prevX) * 0.005;
        const dy = (e.clientY - prevY) * 0.005;
        targetAngleY += dx;
        targetAngleX += dy;
        targetAngleX = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, targetAngleX));
        prevX = e.clientX;
        prevY = e.clientY;
      });

      window.addEventListener('mouseup', () => { isDragging = false; });

      // Touch support
      canvas.addEventListener('touchstart', (e) => {
        isDragging = true;
        prevX = e.touches[0].clientX;
        prevY = e.touches[0].clientY;
        hasInteracted = true;
        lastInteraction = performance.now();
      }, { passive: true });

      canvas.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const dx = (e.touches[0].clientX - prevX) * 0.005;
        const dy = (e.touches[0].clientY - prevY) * 0.005;
        targetAngleY += dx;
        targetAngleX += dy;
        targetAngleX = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, targetAngleX));
        prevX = e.touches[0].clientX;
        prevY = e.touches[0].clientY;
      }, { passive: true });

      canvas.addEventListener('touchend', () => { isDragging = false; });

      // Zoom
      canvas.addEventListener('wheel', (e) => {
        e.preventDefault();
        uniforms.uZoom.value *= e.deltaY > 0 ? 0.95 : 1.05;
        uniforms.uZoom.value = Math.max(0.3, Math.min(3.0, uniforms.uZoom.value));
        hasInteracted = true;
        lastInteraction = performance.now();
      }, { passive: false });

      // ─── Resize ───
      window.addEventListener('resize', () => {
        const newDpr = Math.min(window.devicePixelRatio, 2);
        renderer.setSize(window.innerWidth, window.innerHeight);
        uniforms.uResolution.value.set(window.innerWidth * newDpr, window.innerHeight * newDpr);
      });

      // ─── Hint fade ───
      const hintEl = document.getElementById('hint')!;
      setTimeout(() => {
        hintEl.style.opacity = '0';
      }, 5000);

      // ─── Animate ───
      const clock = new THREE.Clock();

      function animate() {
        requestAnimationFrame(animate);

        const elapsed = clock.getElapsedTime();
        uniforms.uTime.value = elapsed;

        // Auto-rotate when idle
        const timeSinceInteraction = performance.now() - lastInteraction;
        if (!isDragging && timeSinceInteraction > 3000) {
          targetAngleY += 0.0008;
        }

        // Smooth lerp
        autoAngleY += (targetAngleY - autoAngleY) * 0.06;
        autoAngleX += (targetAngleX - autoAngleX) * 0.06;
        uniforms.uMouse.value.set(autoAngleX, autoAngleY);

        renderer.render(scene, camera);
      }

      animate();
    </script>
  </body>
</html>
