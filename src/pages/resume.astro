---
import Base from '../layouts/Base.astro';
---

<Base title="Resume" description="Nicholas Yeager — AI Solutions Architect, resume and work history.">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-xs text-terminal-muted uppercase tracking-widest">resume</h1>
    <a href="/resume.pdf" target="_blank" rel="noopener noreferrer"
      class="text-xs text-terminal-muted border border-terminal-border rounded px-3 py-1.5 hover:text-terminal-green hover:border-terminal-dim transition-colors duration-200 cursor-pointer">
      download pdf &darr;
    </a>
  </div>

  <div class="max-w-xl font-sans">

    <!-- Header -->
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-terminal-text mb-1">Nicholas Yeager</h2>
      <p class="text-sm text-terminal-muted">Tucson, Arizona &middot; (760) 996-7075 &middot;
        <a href="mailto:yeag123@gmail.com" class="hover:text-terminal-green transition-colors duration-200 cursor-pointer">yeag123@gmail.com</a> &middot;
        <a href="https://www.linkedin.com/in/nicholas-yeager/" target="_blank" rel="noopener noreferrer" class="hover:text-terminal-green transition-colors duration-200 cursor-pointer">LinkedIn</a> &middot;
        <a href="https://github.com/nickyeager" target="_blank" rel="noopener noreferrer" class="hover:text-terminal-green transition-colors duration-200 cursor-pointer">GitHub</a>
      </p>
    </div>

    <!-- Professional Summary -->
    <section class="mb-8">
      <h3 class="text-xs text-terminal-muted uppercase tracking-widest mb-3 font-mono">Professional Summary</h3>
      <p class="text-sm leading-relaxed text-terminal-text/80">
        Senior AI Solutions Architect with extensive experience leading cross-functional teams in healthcare, finance, entertainment, and nonprofit sectors. Built an industry-first AI pharmaceutical assistant, leveraging full-stack expertise to drive product innovation. Track record of building venture-backed startups. Microsoft Certified: Azure AI Engineer Associate (March 2026).
      </p>
    </section>

    <!-- Work Experience -->
    <section class="mb-8">
      <h3 class="text-xs text-terminal-muted uppercase tracking-widest mb-4 font-mono">Work Experience</h3>

      <div class="space-y-6">
        <div>
          <div class="flex items-start justify-between gap-4">
            <h4 class="text-sm font-semibold text-terminal-text">AI Solutions Architect</h4>
            <span class="text-xs text-terminal-muted shrink-0">Feb 2026 - Present</span>
          </div>
          <p class="text-xs text-terminal-cyan mb-2">ScriptSave &middot; Tucson, Arizona</p>
          <ul class="text-sm text-terminal-text/70 space-y-1 list-disc list-inside">
            <li>Spearheading the architectural design and deployment of AI-driven pharmaceutical solutions.</li>
            <li>Integrating advanced LLM workflows and Azure AI services to enhance product capabilities.</li>
          </ul>
        </div>

        <div>
          <div class="flex items-start justify-between gap-4">
            <h4 class="text-sm font-semibold text-terminal-text">Lead Engineer</h4>
            <span class="text-xs text-terminal-muted shrink-0">Feb 2022 - Feb 2026</span>
          </div>
          <p class="text-xs text-terminal-cyan mb-2">ScriptSave &middot; Tucson, Arizona</p>
          <ul class="text-sm text-terminal-text/70 space-y-1 list-disc list-inside">
            <li>Implemented modern project management methods and frameworks to drive team alignment and efficiency.</li>
            <li>Deployed multiple new products using modern APIs.</li>
          </ul>
        </div>

        <div>
          <div class="flex items-start justify-between gap-4">
            <h4 class="text-sm font-semibold text-terminal-text">Software Engineer</h4>
            <span class="text-xs text-terminal-muted shrink-0">Jan 2024 - Present</span>
          </div>
          <p class="text-xs text-terminal-cyan mb-2">Delta Thermal Inc &middot; Tucson, Arizona</p>
        </div>

        <div>
          <div class="flex items-start justify-between gap-4">
            <h4 class="text-sm font-semibold text-terminal-text">Software Engineer</h4>
            <span class="text-xs text-terminal-muted shrink-0">Feb 2021 - Feb 2022</span>
          </div>
          <p class="text-xs text-terminal-cyan mb-2">Alicat Scientific &middot; Tucson, Arizona</p>
          <ul class="text-sm text-terminal-text/70 space-y-1 list-disc list-inside">
            <li>Modernized a legacy backend and frontend system.</li>
            <li>Introduced deployment workflows that reduced downtime and errors in a legacy environment.</li>
            <li>Developed a custom CI solution to automate integrations and accelerate release cycles.</li>
            <li>Implemented thorough testing and raised coverage for a large CRM platform.</li>
          </ul>
        </div>

        <div>
          <div class="flex items-start justify-between gap-4">
            <h4 class="text-sm font-semibold text-terminal-text">Software Engineer</h4>
            <span class="text-xs text-terminal-muted shrink-0">Apr 2021 - Dec 2021</span>
          </div>
          <p class="text-xs text-terminal-cyan mb-2">USAA &middot; Phoenix, Arizona</p>
          <ul class="text-sm text-terminal-text/70 space-y-1 list-disc list-inside">
            <li>Rebuilt core frontend components for their umbrella insurance application.</li>
            <li>Established updated testing and deployment workflows to improve release consistency.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Additional Experience -->
    <section class="mb-8">
      <h3 class="text-xs text-terminal-muted uppercase tracking-widest mb-4 font-mono">Additional Experience</h3>
      <div class="space-y-2 text-sm text-terminal-text/70">
        <div class="flex items-start justify-between gap-4">
          <span><span class="text-terminal-text/90 font-medium">Senior Architect</span> &middot; overlandbound.com</span>
          <span class="text-xs text-terminal-muted shrink-0">Jan - Jun 2020</span>
        </div>
        <div class="flex items-start justify-between gap-4">
          <span><span class="text-terminal-text/90 font-medium">Co-Founder & CTO</span> &middot; Quoteapro</span>
          <span class="text-xs text-terminal-muted shrink-0">Nov 2017 - Jan 2020</span>
        </div>
        <div class="flex items-start justify-between gap-4">
          <span><span class="text-terminal-text/90 font-medium">Founder & Partner</span> &middot; Rincon Strategies</span>
          <span class="text-xs text-terminal-muted shrink-0">Apr 2015 - Nov 2017</span>
        </div>
        <div class="flex items-start justify-between gap-4">
          <span><span class="text-terminal-text/90 font-medium">Developer / Project Manager</span> &middot; Elegant Thought</span>
          <span class="text-xs text-terminal-muted shrink-0">Jan 2011 - Apr 2015</span>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="mb-8">
      <h3 class="text-xs text-terminal-muted uppercase tracking-widest mb-3 font-mono">Education</h3>
      <p class="text-sm text-terminal-text/80">Bachelor of Arts in Political Science and Government</p>
      <p class="text-xs text-terminal-muted">University of Arizona &middot; Tucson, Arizona</p>
    </section>

    <!-- Skills -->
    <section class="mb-8">
      <h3 class="text-xs text-terminal-muted uppercase tracking-widest mb-4 font-mono">Skills</h3>
      <div class="space-y-3 text-sm">
        <div>
          <span class="text-terminal-text/90 font-medium">Leadership:</span>
          <span class="text-terminal-text/70"> Team leadership, Cross-functional collaboration, Public speaking</span>
        </div>
        <div>
          <span class="text-terminal-text/90 font-medium">AI & Cloud:</span>
          <span class="text-terminal-text/70"> Azure AI Services, LLM Integration, Prompt Engineering</span>
        </div>
        <div>
          <span class="text-terminal-text/90 font-medium">Backend:</span>
          <span class="text-terminal-text/70"> .NET Core, Laravel, Node.js, Phoenix, Flask</span>
        </div>
        <div>
          <span class="text-terminal-text/90 font-medium">Frontend:</span>
          <span class="text-terminal-text/70"> ReactJS, React Native, Blazor</span>
        </div>
        <div>
          <span class="text-terminal-text/90 font-medium">Languages:</span>
          <span class="text-terminal-text/70"> Python, PHP, TypeScript, JavaScript, Objective-C, Ruby, HTML, CSS, SQL, C#</span>
        </div>
      </div>
    </section>

    <!-- Hobbies -->
    <section>
      <h3 class="text-xs text-terminal-muted uppercase tracking-widest mb-3 font-mono">Hobbies</h3>
      <p class="text-sm text-terminal-text/70">Pickleball Coach</p>
    </section>

  </div>
</Base>
