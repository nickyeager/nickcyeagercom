---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const talks = (await getCollection('talks'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title="Talks">
  <h1 class="text-xs text-terminal-muted uppercase tracking-widest mb-8">talks</h1>

  {talks.length === 0 && (
    <p class="text-terminal-muted text-sm">No talks yet. Check back soon.</p>
  )}

  <ul class="space-y-8">
    {talks.map((talk) => (
      <li class="group">
        <a href={`/talks/${talk.id}`} class="block cursor-pointer">
          <div class="flex items-baseline gap-3">
            <span class="text-terminal-muted text-xs font-mono shrink-0">{talk.data.date}</span>
            <span class="text-terminal-text group-hover:text-terminal-green transition-colors duration-200 font-medium">
              {talk.data.title}
            </span>
          </div>
          <div class="ml-[calc(10ch+0.75rem)] mt-1">
            <p class="text-xs text-terminal-muted">@ {talk.data.event}</p>
            <p class="text-sm text-terminal-text mt-1 font-sans">{talk.data.description}</p>
            <div class="flex gap-3 mt-2">
              {talk.data.slides && (
                <span class="text-[10px] text-terminal-dim border border-terminal-border px-1.5 py-0.5 rounded">
                  slides
                </span>
              )}
              {talk.data.video && (
                <span class="text-[10px] text-terminal-dim border border-terminal-border px-1.5 py-0.5 rounded">
                  video
                </span>
              )}
            </div>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>
